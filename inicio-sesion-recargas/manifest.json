{
    "manifest_version": 2,
    "name": "Inicio de Sesión Recargas",
    "version": "1.7",
    "description": "Facilita el inicio de sesión llenando automáticamente tu cuenta.",

    "content_scripts": [
        {
            "matches": ["https://web.movivendor.com/login"],
            "js": ["autocompletar-numero.js"],
            "run_at": "document_end"
        }
    ],

    "background": {
        "scripts": ["background.js"]
    },

    "browser_action": {
        "default_title": "Reintentar autocompletar",
        "default_icon": {
            "16": "icon.png",
            "32": "icon.png"
        }
    },

    "options_ui": {
        "page": "opciones.html",
        "open_in_tab": true
    },

    "permissions": [
        "storage",
        "tabs",
        "https://web.movivendor.com/login"
    ],

    "data_collection_permissions": {
        "collects_data": false
    },

    "browser_specific_settings": {
        "gecko": {
            "id": "{794dae10-ad39-4e90-8726-5951722c2322}"
        }
    }
}
